# Example environment file for DevLake
# Copy this file to .env and replace placeholder values.

# Basic Configuration
DB_URL=mysql://merico:merico@mysql:3306/lake?charset=utf8mb4&parseTime=True
PORT=:8080

# Required Secret
# Generate a strong random secret (base64), for example:
# openssl rand -base64 32
ENCRYPTION_SECRET=REPLACE_WITH_BASE64_SECRET

# Advanced Configuration (Optional)
# API_TIMEOUT=120s
# API_RETRY=3
# API_REQUESTS_PER_HOUR=10000
# PIPELINE_MAX_PARALLEL=1
# LOGGING_DIR=/app/logs
# LOGGING_LEVEL=info

# Config UI Credentials
ADMIN_USER=admin
ADMIN_PASS=admin
